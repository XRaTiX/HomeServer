[Unit]
Description=Stow dotfiles from DockerSettings
ConditionPathExists=!/home/core/.dotfiles-stowed

[Service]
Type=oneshot
User=core
Restart=on-failure
RestartSec=30s
ExecStart=/usr/bin/stow --dir=/home/core/DockerSettings \
    --target=/home/core "Host Settings"
ExecStart=/bin/touch /home/core/.dotfiles-stowed
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target